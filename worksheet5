    <h4>3. Jaroslav Hašek: Osudy dobrého vojáka Švejka</h4>
    <ul>
        <li>Humoristický a satirický román, nedokončený.</li>
        <li>Švejk svojou „poslušnosťou“ ukazuje hlúposť armády.</li>
        <li>Na odvod ide na vozíku, pretože má reumu.</li>
        <li>Slúži u poľného kuráta a neskôr u nadporučíka Lukáša.</li>
        <li>Dielo má 4 samostatné romány.</li>
        <li>Hlavná zbraň proti vojne je humor.</li>
        <li>Zosmiešňuje militarizmus a byrokraciu Rakúsko-Uhorska.</li>
    </ul>
</div>
</div>

<script>
const correct = {
  q1: 'a', q2: 'b', q3: 'a', q4: 'b', q5: 'a', q6: 'b', q7: 'a',
  q8: 'b', q9: 'a', q10: 'b', q11: 'a', q12: 'b', q13: 'a', q14: 'b',
  q15: 'a', q16: 'b', q17: 'a', q18: 'b', q19: 'a', q20: 'b', q21: 'a'
};

let currentPart = 1;

function showPart(n) {
  currentPart = n;
  document.querySelectorAll('.question').forEach(function(q){
    q.style.display = (q.dataset.part === String(n)) ? 'block' : 'none';
  });
  document.querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('active'); });
  document.getElementById('tabBtn' + n).classList.add('active');
  document.getElementById('result').textContent = '';
}

function hintClick(btn) {
  const wrap = btn.parentElement;
  const reveal = wrap.querySelector('.hint-reveal');
  const stage = wrap.dataset.stage || "0";
  if (stage === "0") {
    reveal.textContent = wrap.dataset.hint1;
    reveal.style.display = 'block';
    btn.textContent = '💡 Ešte nápoveda?';
    wrap.dataset.stage = "1";
  } else if (stage === "1") {
    reveal.textContent = wrap.dataset.hint2;
    reveal.style.display = 'block';
    btn.textContent = '🙈 Skryť fakt';
    wrap.dataset.stage = "2";
  } else if (stage === "2") {
    reveal.style.display = 'none';
    btn.textContent = '👁️ Zobraziť fakt';
    wrap.dataset.stage = "3";
  } else if (stage === "3") {
    reveal.style.display = 'block';
    btn.textContent = '🙈 Skryť fakt';
    wrap.dataset.stage = "2";
  }
}

function resetHints() {
  document.querySelectorAll('.hint-wrap').forEach(function(wrap){
    if (wrap.closest('.question').dataset.part !== String(currentPart)) return;
    wrap.dataset.stage = "0";
    const reveal = wrap.querySelector('.hint-reveal');
    reveal.style.display = 'none';
    reveal.textContent = '';
    const btn = wrap.querySelector('.hint-btn');
    btn.textContent = '💡 Pomoc';
    btn.disabled = false;
  });
}

function checkAnswers() {
  let score = 0, total = 0;
  document.querySelectorAll('.question').forEach(function(q){
    if (q.dataset.part !== String(currentPart)) return;
    const sel = q.querySelector('select');
    if (!sel) return;
    total++;
    if (sel.value === correct[sel.id]) {
      sel.style.border = '2px solid green';
      sel.style.backgroundColor = '#e6ffe6';
      score++;
    } else if (sel.value === '') {
      sel.style.border = '1px solid #ccc';
      sel.style.backgroundColor = '#fff';
    } else {
      sel.style.border = '2px solid red';
      sel.style.backgroundColor = '#ffe6e6';
    }
  });
  document.getElementById('result').textContent = 'Skóre za túto časť: ' + score + ' z ' + total;
}

function resetPart() {
  document.querySelectorAll('.question').forEach(function(q){
    if (q.dataset.part !== String(currentPart)) return;
    const sel = q.querySelector('select');
    if (sel) {
      sel.value = "";
      sel.style.border = '1px solid #ccc';
      sel.style.backgroundColor = '#fff';
    }
  });
  resetHints();
  document.getElementById('result').textContent = '';
  saveAnswers();
}

function toggleAppendix() {
  const panel = document.getElementById('appendixPanel');
  const isHidden = getComputedStyle(panel).display === 'none';
  panel.style.display = isHidden ? 'block' : 'none';
}

const STORAGE_KEY = 'englishWorksheets_worksheet4_v2';
function saveAnswers(){
  const data = {};
  document.querySelectorAll('select[id^="q"]').forEach(function(sel){ if (sel.value) data[sel.id] = sel.value; });
  localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
}
function loadAnswers(){
  try {
    const data = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
    for (const id in data) {
      const sel = document.getElementById(id);
      if (sel) sel.value = data[id];
    }
  } catch(e) {}
}
document.querySelectorAll('select[id^="q"]').forEach(function(sel){ sel.addEventListener('change', saveAnswers); });

loadAnswers();
showPart(1);
</script>

</body>
</html>
